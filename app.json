{
  "expo": {
    "name": "StarterBuddy",
    "slug": "StarterBuddy",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#F4EFE6"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.starterbuddy.app",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "This identifier may be used to deliver ads and improve app experience.",
        "SKAdNetworkItems": [
          {
            "SKAdNetworkIdentifier": "cstr6suwn9.skadnetwork"
          }
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "plugins": [
      "expo-sqlite",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#7A4E2D"
        }
      ],
      [
        "react-native-google-mobile-ads",
        {
          "iosAppId": "ca-app-pub-8297854143810721~1912218863",
          "androidAppId": "ca-app-pub-REPLACE_ME~REPLACE_ME"
        }
