    "extra": {
      "_releaseNotes": "Replace via EAS secrets or app config before release",
      "revenuecat": {
        "iosPublicSdkKey": "appl_BvLshhWmYBJuKgAWWLxsEzdhyKL",
        "androidPublicSdkKey": "goog_REPLACE_ME"
      },
      "admob": {
        "iosBannerUnitId": "ca-app-pub-8297854143810721/4691091721",
        "androidBannerUnitId": "ca-app-pub-REPLACE_ME"
      },
      "eas": {
        "projectId": "d86ff932-3ced-46dd-8463-b01a85142524"
      }
